function Util.Debounce(fn, time)
    local last = 0
    return function(...)
        local now = tick()
        if now - last >= time then
            last = now
            return fn(...)
        end
    end
end

function Util.Throttle(fn, time)
    local last = 0
    local pending = nil
    local timer = nil
    local args = nil
    return function(...)
        args = {...}
        local now = tick()
        if now - last >= time then
            last = now
            fn(table.unpack(args))
        elseif not timer then
            timer = task.delay(time - (now - last), function()
                last = tick()
                timer = nil
                fn(table.unpack(args))
            end)
        end
    end
end

function Util.TableContains(tbl, value)
    for _, v in ipairs(tbl) do
        if v == value then return true end
    end
    return false
end

function Util.TableRemove(tbl, value)
    for i, v in ipairs(tbl) do
        if v == value then
            table.remove(tbl, i)
            return true
        end
    end
    return false
end

function Util.TableCopy(tbl)
    local new = {}
    for k, v in pairs(tbl) do
        if type(v) == "table" then
            new[k] = Util.TableCopy(v)
        else
            new[k] = v
        end
    end
    return new
end

function Util.TableMerge(a, b)
    local merged = Util.TableCopy(a)
    for k, v in pairs(b) do
        merged[k] = v
    end
    return merged
end

function Util.PlatformInput(input)
    return input.UserInputType == Enum.UserInputType.MouseButton1
        or input.UserInputType == Enum.UserInputType.Touch
end

