            box.Size = UDim2.new(1, -12, 1, -12)
            box.Position = UDim2.new(0, 6, 0, 6)
        end
        local charCounter
        if maxChars and not multiLine then
            charCounter = Util.Label(wrapper, {
                Text = #current .. "/" .. maxChars,
                Color = theme.TextTertiary,
                Size = LedZ.Design.TextTiny,
                Font = LedZ.Fonts.Body,
                FrameSize = UDim2.new(0, 50, 0, 14),
                Position = UDim2.new(1, -60, 1, -16),
                AlignX = Enum.TextXAlignment.Right,
                ZIndex = 4,
            })
        end
        Util.Connect(box.Focused, function()
            Util.Tween(inputBG, { BackgroundColor3 = theme.InputBGFocused }, 0.15)
            inputStroke.Color = theme.BorderFocused
            inputStroke.Transparency = 0
        end)
        Util.Connect(box.FocusLost, function(enter)
            Util.Tween(inputBG, { BackgroundColor3 = theme.InputBG }, 0.15)
            inputStroke.Color = theme.Border
            local val = box.Text
            if validator then
                local ok, err = pcall(validator, val)
                if ok and err == false then
                    inputStroke.Color = theme.Error
                    box.Text = current
                    return
                end
            end
            current = val
            if onFinish then pcall(onFinish, val) end
        end)
        Util.Connect(box:GetPropertyChangedSignal("Text"), function()
            local v = box.Text
            if password then
                if not box:GetAttribute("_showing") then
                end
            end
            if maxChars and #v > maxChars then
                box.Text = v:sub(1, maxChars)
                return
            end
            if numeric then
                local cleaned = v:gsub("[^%d%.%-]", "")
                if cleaned ~= v then
                    box.Text = cleaned
                    return
                end
            end
            if charCounter then
                charCounter.Text = #box.Text .. "/" .. maxChars
                charCounter.TextColor3 = #box.Text >= maxChars and theme.Warning or theme.TextTertiary
            end
            current = box.Text
            pcall(inputCallback, box.Text)
        end)
        if tooltip then self_ref:AttachTooltip(wrapper, tooltip) end
        local Input = { _wrapper = wrapper, _box = box }
        function Input:Set(v) box.Text = tostring(v); current = box.Text end
        function Input:Get() return current end
        function Input:SetPlaceholder(p) box.PlaceholderText = p end
        function Input:SetCallback(fn) inputCallback = fn end
        function Input:Focus() box:CaptureFocus() end
        function Input:Destroy() wrapper:Destroy() end
        if key then
            self_ref:RegisterConfigElement(self._window or Window, key,
                function() return current end,
                function(v) Input:Set(v) end
            )
        end
        return Input
    end
