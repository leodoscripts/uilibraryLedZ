    local ripple = Instance.new("Frame")
    ripple.BackgroundColor3 = color or Color3.new(1, 1, 1)
    ripple.BackgroundTransparency = transparency or 0.85
    ripple.BorderSizePixel = 0
    ripple.ZIndex = (button.ZIndex or 1) + 5
    Util.Round(ripple, UDim.new(1, 0))
    local mouse = UserInputService:GetMouseLocation()
    local abs = button.AbsolutePosition
    local relX = mouse.X - abs.X
    local relY = mouse.Y - abs.Y - 36
    local size = math.max(button.AbsoluteSize.X, button.AbsoluteSize.Y) * 2.2
    ripple.Size = UDim2.new(0, 0, 0, 0)
    ripple.Position = UDim2.new(0, relX, 0, relY)
    ripple.AnchorPoint = Vector2.new(0.5, 0.5)
    ripple.Parent = button
    Util.Tween(ripple, {
        Size = UDim2.new(0, size, 0, size),
        BackgroundTransparency = 1,
    }, 0.5, Enum.EasingStyle.Quad, Enum.EasingDirection.Out)
    Debris:AddItem(ripple, 0.6)
end

