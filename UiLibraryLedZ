            Font = LedZ.Fonts.Label,
            FrameSize = UDim2.new(0.6, -leftOffset, 1, 0),
            Position = UDim2.new(0, leftOffset, 0, 0),
            ZIndex = 4,
        })
        local kbBG = Util.Frame(wrapper, {
            Color = theme.InputBG,
            Size = UDim2.new(0, 100, 0, 24),
            Position = UDim2.new(1, -112, 0.5, -12),
            ZIndex = 4,
        })
        Util.Round(kbBG, UDim.new(0, 5))
        Util.Stroke(kbBG, theme.Border)
        local function keyName(k)
            if not k then return "None" end
            if typeof(k) == "EnumItem" then return k.Name end
            return tostring(k)
        end
        local kbLbl = Util.Label(kbBG, {
            Text = keyName(current),
            Color = theme.Accent,
            Size = LedZ.Design.TextSmall,
            Font = LedZ.Fonts.Heading,
            FrameSize = UDim2.new(1, 0, 1, 0),
            AlignX = Enum.TextXAlignment.Center,
            ZIndex = 5,
        })
        local clickBtn = Util.Button(wrapper, {
            FrameSize = UDim2.new(1, 0, 1, 0),
            Color = Color3.new(0,0,0),
            Transparency = 1,
            Text = "",
            ZIndex = 6,
        })
        Util.Connect(clickBtn.MouseButton1Click, function()
            listening = true
            kbLbl.Text = "..."
            kbLbl.TextColor3 = theme.Warning
            Util.Tween(kbBG, { BackgroundColor3 = theme.ElementHover }, 0.15)
        end)
        Util.Connect(UserInputService.InputBegan, function(input, processed)
            if listening then
                local newKey
                if input.UserInputType == Enum.UserInputType.Keyboard then
                    newKey = input.KeyCode
                elseif allowMouse and (
                    input.UserInputType == Enum.UserInputType.MouseButton1 or
                    input.UserInputType == Enum.UserInputType.MouseButton2 or
                    input.UserInputType == Enum.UserInputType.MouseButton3
                ) then
                    newKey = input.UserInputType
                end
                if newKey then
                    if newKey == Enum.KeyCode.Escape then
                        current = nil
                    else
                        current = newKey
                    end
                    kbLbl.Text = keyName(current)
                    kbLbl.TextColor3 = theme.Accent
                    Util.Tween(kbBG, { BackgroundColor3 = theme.InputBG }, 0.15)
                    listening = false
                end
                return
            end
            if processed then return end
            if not current then return end
            local matches = false
            if typeof(current) == "EnumItem" then
                if input.KeyCode == current then matches = true end
                if input.UserInputType == current then matches = true end
            end
            if matches then
                if mode == "Toggle" then
                    pcall(kbCallback)
                elseif mode == "Hold" then
                    pcall(kbCallback, true)
                end
            end
        end)
        Util.Connect(UserInputService.InputEnded, function(input, processed)
            if processed then return end
            if mode == "Hold" and current then
                local matches = false
                if typeof(current) == "EnumItem" then
                    if input.KeyCode == current then matches = true end
                    if input.UserInputType == current then matches = true end
                end
                if matches then pcall(kbCallback, false) end
            end
        end)
        if tooltip then self_ref:AttachTooltip(wrapper, tooltip) end
        local Keybind = { _wrapper = wrapper }
        function Keybind:Set(k)
            current = k
            kbLbl.Text = keyName(current)
        end
        function Keybind:Get() return current end
        function Keybind:SetCallback(fn) kbCallback = fn end
        function Keybind:SetMode(m) mode = m end
        function Keybind:Destroy() wrapper:Destroy() end
        if key then
            self_ref:RegisterConfigElement(self._window or Window, key,
                function() return current end,
                function(v) Keybind:Set(v) end
            )
        end
        return Keybind
    end
