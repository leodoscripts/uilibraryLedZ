function LedZ:GetIcon(name)
    if not name then return nil end
    if type(name) == "string" and name:match("^rbxasset") then
        return name
    end
    local resolved = self.IconAliases[name] or name
    return self.Icons[resolved]
end
local Util = {}

local activeConnections = {}
local activeTweens = {}

function Util.Track(connection)
    table.insert(activeConnections, connection)
    return connection
end

function Util.Connect(signal, fn)
    local conn = signal:Connect(fn)
    table.insert(activeConnections, conn)
    return conn
end

function Util.DisconnectAll()
    for i = #activeConnections, 1, -1 do
        local conn = activeConnections[i]
        if conn and conn.Connected then
            pcall(function() conn:Disconnect() end)
        end
        activeConnections[i] = nil
    end
end

function Util.Tween(instance, properties, duration, style, direction)
    if not instance or not instance.Parent then return nil end
    local info = TweenInfo.new(
        duration or LedZ.Design.TweenNormal,
        style or Enum.EasingStyle.Quart,
        direction or Enum.EasingDirection.Out
    )
    local existing = activeTweens[instance]
    if existing then
        pcall(function() existing:Cancel() end)
    end
    local t = TweenService:Create(instance, info, properties)
    activeTweens[instance] = t
    t.Completed:Connect(function()
        if activeTweens[instance] == t then
            activeTweens[instance] = nil
        end
    end)
    t:Play()
    return t
end

