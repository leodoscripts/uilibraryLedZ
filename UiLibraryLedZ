            local svDragging = false
            local function updateSV(pos)
                local abs = svSquare.AbsolutePosition
                local size = svSquare.AbsoluteSize
                s = Util.Clamp((pos.X - abs.X) / size.X, 0, 1)
                v = 1 - Util.Clamp((pos.Y - abs.Y) / size.Y, 0, 1)
                svCursor.Position = UDim2.new(s, -5, 1 - v, -5)
                updateSwatch()
            end
            Util.Connect(svBtn.InputBegan, function(input)
                if Util.PlatformInput(input) then
                    svDragging = true
                    updateSV(input.Position)
