                    updateSV(input.Position)
                end
            end)
            local hueStrip = Util.Frame(popup, {
                Color = Color3.new(1,1,1),
                Size = UDim2.new(0, 18, 0, 140),
                Position = UDim2.new(0, 160, 0, 10),
