    function Window:_RethemeAll()
        local t = self._theme
        local function reapply(inst)
            if inst:GetAttribute("LedZRole") == "windowbg" then
                inst.BackgroundColor3 = t.WindowBG
            elseif inst:GetAttribute("LedZRole") == "sidebar" then
                inst.BackgroundColor3 = t.SidebarBG
            elseif inst:GetAttribute("LedZRole") == "topbar" then
                inst.BackgroundColor3 = t.TopbarBG
            elseif inst:GetAttribute("LedZRole") == "element" then
                inst.BackgroundColor3 = t.ElementBG
            elseif inst:GetAttribute("LedZRole") == "accent" then
                inst.BackgroundColor3 = t.Accent
            elseif inst:GetAttribute("LedZRole") == "border" then
                inst.BackgroundColor3 = t.Border
            end
            for _, child in ipairs(inst:GetChildren()) do
                reapply(child)
            end
        end
        reapply(self._main)
    end
