local function ensureConfigFolder()
    if not writefile then return false end
    safeMakeFolder(LedZ.ConfigFolder)
    safeMakeFolder(LedZ.ConfigFolder .. "/Configs")
    return true
end

function LedZ:RegisterConfigElement(window, key, getter, setter)
    if not window._configElements then
        window._configElements = {}
    end
    window._configElements[key] = { Get = getter, Set = setter }
end

function LedZ:SaveConfig(window, name)
    if not ensureConfigFolder() then
        self:Notify({
            Title = "Save Failed",
            Message = "Executor doesn't support file operations.",
            Type = "error",
        })
        return false
    end
    name = name or "default"
    local data = {}
    if window._configElements then
        for key, ctrl in pairs(window._configElements) do
            local ok, val = pcall(ctrl.Get)
            if ok then
                if typeof(val) == "Color3" then
                    data[key] = { _type = "Color3", value = self.Util.ColorToHex(val) }
                elseif typeof(val) == "EnumItem" then
                    data[key] = { _type = "EnumItem", enum = tostring(val.EnumType), name = val.Name }
                elseif typeof(val) == "Vector2" then
                    data[key] = { _type = "Vector2", x = val.X, y = val.Y }
                elseif type(val) == "table" then
                    data[key] = { _type = "table", value = val }
                else
                    data[key] = { _type = type(val), value = val }
                end
            end
        end
    end
    data._meta = {
        version = LedZ.__version,
        timestamp = os.time(),
        theme = self.ActiveTheme.Name,
    }
    local path = self.ConfigFolder .. "/Configs/" .. name .. ".json"
    local ok, encoded = pcall(HttpService.JSONEncode, HttpService, data)
    if not ok then
        self:Notify({ Title = "Save Failed", Message = "Could not encode config.", Type = "error" })
        return false
    end
    local saved = safeWriteFile(path, encoded)
    if saved then
        self:Notify({
            Title = "Config Saved",
            Message = "Saved as '" .. name .. "'.",
            Type = "success",
            Duration = 3,
        })
    end
    return saved
end

function LedZ:LoadConfig(window, name)
    if not ensureConfigFolder() then return false end
    name = name or "default"
    local path = self.ConfigFolder .. "/Configs/" .. name .. ".json"
    local raw = safeReadFile(path)
    if not raw then
        self:Notify({
            Title = "Load Failed",
            Message = "Config '" .. name .. "' not found.",
            Type = "error",
        })
        return false
    end
    local ok, data = pcall(HttpService.JSONDecode, HttpService, raw)
    if not ok then
        self:Notify({ Title = "Load Failed", Message = "Could not parse config.", Type = "error" })
        return false
    end
    if window._configElements then
        for key, ctrl in pairs(window._configElements) do
            local entry = data[key]
            if entry then
                local val = entry.value
                if entry._type == "Color3" then
                    val = self.Util.HexToColor(entry.value)
                elseif entry._type == "EnumItem" then
                    local enumType = Enum[entry.enum:gsub("Enum%.", "")]
                    if enumType then
                        for _, item in ipairs(enumType:GetEnumItems()) do
                            if item.Name == entry.name then val = item; break end
                        end
                    end
                elseif entry._type == "Vector2" then
                    val = Vector2.new(entry.x, entry.y)
                end
                pcall(ctrl.Set, val)
            end
        end
    end
    self:Notify({
        Title = "Config Loaded",
        Message = "Loaded '" .. name .. "'.",
        Type = "success",
        Duration = 3,
    })
    return true
end

function LedZ:DeleteConfig(name)
    if not ensureConfigFolder() then return false end
    local path = self.ConfigFolder .. "/Configs/" .. name .. ".json"
    safeDelFile(path)
    return true
end

function LedZ:ListConfigs()
    if not ensureConfigFolder() then return {} end
    local files = safeListFiles(self.ConfigFolder .. "/Configs")
    local configs = {}
    for _, file in ipairs(files) do
        local fname = file:match("([^/\\]+)%.json$")
        if fname then
            table.insert(configs, fname)
        end
    end
    return configs
end
