    function TabMeta:AddKeybind(opts, callback)
        opts = opts or {}
        local kbText = opts.Text or opts.Name or "Keybind"
        local kbIcon = opts.Icon
        local kbDefault = opts.Default
        local kbCallback = opts.Callback or callback or function() end
        local mode = opts.Mode or "Toggle"
