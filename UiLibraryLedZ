                            Util.Stroke(checkBox, isSelected(item) and theme.Accent or theme.Border)
                            if isSelected(item) then
                                Util.Image(checkBox, {
                                    Image = self_ref:GetIcon("check"),
                                    Color = Color3.new(1,1,1),
                                    Size = UDim2.new(0, 10, 0, 10),
                                    Position = UDim2.new(0.5, -5, 0.5, -5),
                                    ZIndex = 54,
                                })
                            end
                        end
                        Util.Label(itemBtn, {
                            Text = itemStr,
                            Color = isSelected(item) and theme.Accent or theme.TextPrimary,
                            Size = LedZ.Design.TextSmall,
                            Font = LedZ.Fonts.Label,
                            FrameSize = UDim2.new(1, -(multi and 32 or 16), 1, 0),
                            Position = UDim2.new(0, multi and 28 or 8, 0, 0),
                            ZIndex = 53,
                        })
                        Util.Connect(itemBtn.MouseEnter, function()
                            Util.Tween(itemBtn, {
                                BackgroundColor3 = isSelected(item) and theme.AccentDim or theme.ElementHover
                            }, 0.1)
                        end)
                        Util.Connect(itemBtn.MouseLeave, function()
                            Util.Tween(itemBtn, {
                                BackgroundColor3 = isSelected(item) and theme.AccentDim or theme.ElementBG
                            }, 0.1)
                        end)
                        Util.Connect(itemBtn.MouseButton1Click, function()
                            if multi then
                                if Util.TableContains(selected, item) then
                                    Util.TableRemove(selected, item)
                                else
                                    table.insert(selected, item)
                                end
                                rebuildItems(searchBox and searchBox.Text or "")
                                valLbl.Text = formatSelected()
                                pcall(dropCallback, selected)
                            else
                                selected = item
                                valLbl.Text = formatSelected()
                                rebuildItems(searchBox and searchBox.Text or "")
                                pcall(dropCallback, selected)
                                task.wait(0.05)
                                if dropdownPopup then closePopup() end
                            end
                        end)
                        table.insert(itemButtons, itemBtn)
                    end
                end
            end
            rebuildItems("")
            if searchBox then
                Util.Connect(searchBox:GetPropertyChangedSignal("Text"), function()
                    rebuildItems(searchBox.Text)
                end)
                searchBox:CaptureFocus()
            end
            popup.Size = UDim2.new(0, valBG.AbsoluteSize.X, 0, 0)
            local targetH = math.min(220, (#items * 30) + (searchable and 38 or 8))
            Util.Tween(popup, {
                Size = UDim2.new(0, valBG.AbsoluteSize.X, 0, targetH)
            }, 0.2, Enum.EasingStyle.Quart)
            return popup
        end
        function closePopup()
            if not dropdownPopup then return end
            isOpen = false
            Util.Tween(arrow, { Rotation = 0 }, 0.18)
            local p = dropdownPopup
            dropdownPopup = nil
            Util.Tween(p, {
                Size = UDim2.new(p.Size.X.Scale, p.Size.X.Offset, 0, 0)
            }, 0.18)
            task.delay(0.2, function()
                if p and p.Parent then p:Destroy() end
            end)
        end
        Util.Connect(clickBtn.MouseButton1Click, function()
            if isOpen then
                closePopup()
            else
                isOpen = true
                Util.Tween(arrow, { Rotation = 180 }, 0.18)
                dropdownPopup = createPopup()
            end
        end)
        Util.Connect(UserInputService.InputBegan, function(input)
            if isOpen and Util.PlatformInput(input) then
                if not dropdownPopup then return end
                local mPos = UserInputService:GetMouseLocation()
                local abs = dropdownPopup.AbsolutePosition
                local size = dropdownPopup.AbsoluteSize
                local valAbs = valBG.AbsolutePosition
                local valSize = valBG.AbsoluteSize
                local inPopup = mPos.X >= abs.X and mPos.X <= abs.X + size.X
                    and mPos.Y >= abs.Y - 36 and mPos.Y <= abs.Y + size.Y - 36
                local inHeader = mPos.X >= valAbs.X and mPos.X <= valAbs.X + valSize.X
                    and mPos.Y >= valAbs.Y - 36 and mPos.Y <= valAbs.Y + valSize.Y - 36
                if not inPopup and not inHeader then
                    closePopup()
                end
            end
        end)
        if tooltip then self_ref:AttachTooltip(wrapper, tooltip) end
        local Dropdown = { _wrapper = wrapper }
        function Dropdown:Set(v)
            selected = v
            valLbl.Text = formatSelected()
        end
        function Dropdown:Get() return selected end
        function Dropdown:Refresh(newItems, keepSelection)
            items = newItems
            if not keepSelection then
                selected = multi and {} or nil
                valLbl.Text = formatSelected()
            end
        end
        function Dropdown:SetCallback(fn) dropCallback = fn end
        function Dropdown:Destroy() wrapper:Destroy() end
        if key then
            self_ref:RegisterConfigElement(self._window or Window, key,
                function() return selected end,
                function(v) Dropdown:Set(v) end
            )
        end
        return Dropdown
    end
