    function TabMeta:AddSlider(opts, callback)
        opts = opts or {}
        local sliderText = opts.Text or opts.Name or "Slider"
        local sliderIcon = opts.Icon
        local sliderMin = opts.Min or 0
        local sliderMax = opts.Max or 100
        local sliderDefault = opts.Default or sliderMin
        local sliderStep = opts.Step or 1
        local sliderSuffix = opts.Suffix or ""
        local sliderPrefix = opts.Prefix or ""
        local decimals = opts.Decimals or 0
        local sliderCallback = opts.Callback or callback or function() end
        local key = opts.Flag or opts.Key
        local tooltip = opts.Tooltip
        local current = Util.Clamp(sliderDefault, sliderMin, sliderMax)
        local function formatValue(v)
            if decimals > 0 then
                return string.format("%." .. decimals .. "f", v)
            else
                return tostring(math.floor(v + 0.5))
            end
        end
        local wrapper = Util.Frame(self._scroll, {
            Color = theme.ElementBG,
            Size = UDim2.new(1, 0, 0, 58),
            Name = "Slider_" .. sliderText,
            ZIndex = 3,
        })
        wrapper.LayoutOrder = self:NextOrder()
        Util.Round(wrapper, UDim.new(0, 6))
        Util.Stroke(wrapper, theme.Border)
        local iconImg
        local leftOffset = 12
        if sliderIcon then
            iconImg = Util.Image(wrapper, {
                Image = self_ref:GetIcon(sliderIcon) or sliderIcon,
                Color = theme.Accent,
                Size = UDim2.new(0, 16, 0, 16),
                Position = UDim2.new(0, 12, 0, 10),
                ZIndex = 4,
            })
            leftOffset = 36
        end
        local textLbl = Util.Label(wrapper, {
            Text = sliderText,
            Color = theme.TextPrimary,
            Size = LedZ.Design.TextNormal,
            Font = LedZ.Fonts.Label,
            FrameSize = UDim2.new(0.6, -leftOffset, 0, 20),
            Position = UDim2.new(0, leftOffset, 0, 8),
            ZIndex = 4,
        })
        local valBG = Util.Frame(wrapper, {
            Color = theme.AccentDim,
            Size = UDim2.new(0, 60, 0, 20),
            Position = UDim2.new(1, -72, 0, 8),
            Name = "ValueBG",
            ZIndex = 4,
        })
        Util.Round(valBG, UDim.new(0, 4))
        local valLbl = Util.Label(valBG, {
            Text = sliderPrefix .. formatValue(current) .. sliderSuffix,
            Color = theme.Accent,
            Size = LedZ.Design.TextSmall,
            Font = LedZ.Fonts.Heading,
            FrameSize = UDim2.new(1, 0, 1, 0),
            AlignX = Enum.TextXAlignment.Center,
            ZIndex = 5,
        })
        local track = Util.Frame(wrapper, {
            Color = theme.Divider,
            Size = UDim2.new(1, -24, 0, 4),
            Position = UDim2.new(0, 12, 1, -16),
            Name = "Track",
            ZIndex = 4,
        })
        Util.Round(track, UDim.new(1, 0))
        local fill = Util.Frame(track, {
            Color = theme.Accent,
            Size = UDim2.new(0, 0, 1, 0),
            ZIndex = 5,
        })
        Util.Round(fill, UDim.new(1, 0))
        Util.Gradient(fill, { theme.Accent, theme.AccentGlow }, 0)
        local handle = Util.Frame(track, {
            Color = theme.ToggleThumb,
            Size = UDim2.new(0, 14, 0, 14),
            Position = UDim2.new(0, 0, 0.5, -7),
            AnchorPoint = Vector2.new(0.5, 0),
            ZIndex = 6,
        })
        Util.Round(handle, UDim.new(1, 0))
        Util.Stroke(handle, theme.Accent, 2)
        Util.Shadow(handle, { Transparency = 0.6, OffsetY = 2, Size = 6 })
        local function updateVisual(v, animate)
            current = Util.Clamp(Util.RoundTo(v, sliderStep), sliderMin, sliderMax)
            local pct = (current - sliderMin) / (sliderMax - sliderMin)
            local dur = animate and 0.1 or 0
            Util.Tween(fill, { Size = UDim2.new(pct, 0, 1, 0) }, dur)
            Util.Tween(handle, { Position = UDim2.new(pct, 0, 0.5, -7) }, dur)
            valLbl.Text = sliderPrefix .. formatValue(current) .. sliderSuffix
        end
        updateVisual(current, false)
        local hitArea = Util.Button(wrapper, {
            FrameSize = UDim2.new(1, 0, 0, 24),
            Position = UDim2.new(0, 0, 1, -24),
            Color = Color3.new(0,0,0),
            Transparency = 1,
            Text = "",
            ZIndex = 7,
        })
        local dragging = false
        local function getVal(inputPos)
            local abs = track.AbsolutePosition
            local size = track.AbsoluteSize
            local rel = Util.Clamp((inputPos.X - abs.X) / size.X, 0, 1)
            return sliderMin + (sliderMax - sliderMin) * rel
        end
        Util.Connect(hitArea.InputBegan, function(input)
            if Util.PlatformInput(input) then
                dragging = true
                local v = getVal(input.Position)
                updateVisual(v, true)
                pcall(sliderCallback, current)
            end
        end)
        Util.Connect(hitArea.InputEnded, function(input)
            if Util.PlatformInput(input) then
                dragging = false
            end
        end)
        Util.Connect(UserInputService.InputChanged, function(input)
            if dragging and (
                input.UserInputType == Enum.UserInputType.MouseMovement or
                input.UserInputType == Enum.UserInputType.Touch
            ) then
                local v = getVal(input.Position)
                updateVisual(v, false)
                pcall(sliderCallback, current)
            end
        end)
        Util.Connect(wrapper.MouseEnter, function()
            Util.Tween(handle, { Size = UDim2.new(0, 16, 0, 16) }, 0.12)
            Util.Tween(handle, { Position = UDim2.new(handle.Position.X.Scale, 0, 0.5, -8) }, 0.12)
        end)
        Util.Connect(wrapper.MouseLeave, function()
            Util.Tween(handle, { Size = UDim2.new(0, 14, 0, 14) }, 0.12)
            Util.Tween(handle, { Position = UDim2.new(handle.Position.X.Scale, 0, 0.5, -7) }, 0.12)
        end)
        if tooltip then
            self_ref:AttachTooltip(wrapper, tooltip)
        end
        local Slider = { _wrapper = wrapper }
        function Slider:Set(v, fire)
            updateVisual(v, true)
            if fire ~= false then pcall(sliderCallback, current) end
        end
        function Slider:Get() return current end
        function Slider:SetRange(min, max)
            sliderMin = min
            sliderMax = max
            updateVisual(current, true)
        end
        function Slider:SetCallback(fn) sliderCallback = fn end
        function Slider:Destroy() wrapper:Destroy() end
        if key then
            self_ref:RegisterConfigElement(self._window or Window, key,
                function() return current end,
                function(v) Slider:Set(v) end
            )
        end
        return Slider
    end
