            hueGrad.Rotation = 90
            hueGrad.Parent = hueStrip
            local hueCursor = Util.Frame(hueStrip, {
                Color = Color3.new(1,1,1),
                Size = UDim2.new(1, 4, 0, 4),
                Position = UDim2.new(0, -2, h, -2),
                ZIndex = 62,
            })
            Util.Round(hueCursor, UDim.new(0, 2))
            Util.Stroke(hueCursor, Color3.new(0,0,0), 1)
            local hueBtn = Util.Button(hueStrip, {
                FrameSize = UDim2.new(1, 0, 1, 0),
                Color = Color3.new(0,0,0),
                Transparency = 1,
                Text = "",
                ZIndex = 63,
            })
            local hueDragging = false
            local function updateHue(pos)
                local abs = hueStrip.AbsolutePosition
                local size = hueStrip.AbsoluteSize
                h = Util.Clamp((pos.Y - abs.Y) / size.Y, 0, 1)
                hueCursor.Position = UDim2.new(0, -2, h, -2)
                satGrad.Color = ColorSequence.new(Color3.new(1,1,1), Color3.fromHSV(h, 1, 1))
                updateSwatch()
            end
            Util.Connect(hueBtn.InputBegan, function(input)
                if Util.PlatformInput(input) then
                    hueDragging = true
                    updateHue(input.Position)
                end
            end)
            Util.Connect(hueBtn.InputEnded, function(input)
                if Util.PlatformInput(input) then hueDragging = false end
            end)
            Util.Connect(UserInputService.InputChanged, function(input)
                if hueDragging and (
                    input.UserInputType == Enum.UserInputType.MouseMovement or
                    input.UserInputType == Enum.UserInputType.Touch
                ) then
                    updateHue(input.Position)
                end
            end)
            local hexBG = Util.Frame(popup, {
                Color = theme.InputBG,
                Size = UDim2.new(0, popupW - 20, 0, 28),
                Position = UDim2.new(0, 10, 0, 160),
                ZIndex = 61,
            })
            Util.Round(hexBG, UDim.new(0, 4))
            Util.Stroke(hexBG, theme.Border)
            Util.Label(hexBG, {
                Text = "HEX",
                Color = theme.TextTertiary,
                Size = LedZ.Design.TextSmall,
                Font = LedZ.Fonts.Heading,
                FrameSize = UDim2.new(0, 30, 1, 0),
                Position = UDim2.new(0, 8, 0, 0),
                ZIndex = 62,
            })
            local hexBox = Util.TextBox(hexBG, {
                Text = Util.ColorToHex(current),
                FrameSize = UDim2.new(1, -50, 1, 0),
                Position = UDim2.new(0, 42, 0, 0),
                Size = LedZ.Design.TextSmall,
                ZIndex = 62,
            })
            Util.Connect(hexBox.FocusLost, function()
                local ok, c = pcall(Color3.fromHex, hexBox.Text:gsub("#", ""))
                if ok then
                    current = c
                    h, s, v = Color3.toHSV(c)
                    svCursor.Position = UDim2.new(s, -5, 1 - v, -5)
                    hueCursor.Position = UDim2.new(0, -2, h, -2)
                    satGrad.Color = ColorSequence.new(Color3.new(1,1,1), Color3.fromHSV(h, 1, 1))
                    swatch.BackgroundColor3 = current
                    pcall(cpCallback, current)
                end
                hexBox.Text = Util.ColorToHex(current)
            end)
            local applyBtn = Util.Button(popup, {
                Text = "Done",
                Color = theme.Accent,
                TextColor = Color3.new(1,1,1),
                Size = LedZ.Design.TextSmall,
                Font = LedZ.Fonts.Heading,
                FrameSize = UDim2.new(0, popupW - 20, 0, 26),
                Position = UDim2.new(0, 10, 0, 196),
                ZIndex = 62,
            })
            Util.Round(applyBtn, UDim.new(0, 5))
            Util.Hoverable(applyBtn, theme.Accent, theme.AccentHover, theme.AccentDim)
            Util.Connect(applyBtn.MouseButton1Click, function()
                closePopup()
            end)
            Util.Connect(UserInputService.InputBegan, function(input)
                if isOpen and Util.PlatformInput(input) then
                    if not popup then return end
                    local mPos = UserInputService:GetMouseLocation()
                    local abs = popup.AbsolutePosition
                    local size = popup.AbsoluteSize
                    local swAbs = swatch.AbsolutePosition
                    local swSize = swatch.AbsoluteSize
                    local inPopup = mPos.X >= abs.X and mPos.X <= abs.X + size.X
                        and mPos.Y >= abs.Y - 36 and mPos.Y <= abs.Y + size.Y - 36
                    local inSwatch = mPos.X >= swAbs.X and mPos.X <= swAbs.X + swSize.X
                        and mPos.Y >= swAbs.Y - 36 and mPos.Y <= swAbs.Y + swSize.Y - 36
                    if not inPopup and not inSwatch then
                        closePopup()
                    end
                end
            end)
            Util.Tween(popup, { Size = UDim2.new(0, popupW, 0, popupH) }, 0.2,
                Enum.EasingStyle.Back, Enum.EasingDirection.Out)
        end
        Util.Connect(swatchBtn.MouseButton1Click, function()
            if isOpen then closePopup() else isOpen = true; openPopup() end
        end)
        if tooltip then self_ref:AttachTooltip(wrapper, tooltip) end
        local CP = { _wrapper = wrapper }
        function CP:Set(c)
            current = c
            h, s, v = Color3.toHSV(c)
            swatch.BackgroundColor3 = c
        end
        function CP:Get() return current end
        function CP:SetCallback(fn) cpCallback = fn end
        function CP:Destroy() wrapper:Destroy() end
        if key then
            self_ref:RegisterConfigElement(self._window or Window, key,
                function() return current end,
                function(v) CP:Set(v) end
            )
        end
        return CP
    end
    function TabMeta:AddProgressBar(opts)
        opts = opts or {}
        local pbText = opts.Text or "Progress"
        local pbDefault = opts.Default or 0
        local showPct = opts.ShowPercent ~= false
        local color = opts.Color or theme.Accent
        local wrapper = Util.Frame(self._scroll, {
            Color = theme.ElementBG,
            Size = UDim2.new(1, 0, 0, 42),
            Name = "Progress_" .. pbText,
            ZIndex = 3,
        })
        wrapper.LayoutOrder = self:NextOrder()
        Util.Round(wrapper, UDim.new(0, 6))
        Util.Stroke(wrapper, theme.Border)
        Util.Label(wrapper, {
            Text = pbText,
            Color = theme.TextPrimary,
            Size = LedZ.Design.TextSmall,
            Font = LedZ.Fonts.Label,
            FrameSize = UDim2.new(1, -60, 0, 16),
            Position = UDim2.new(0, 12, 0, 6),
            ZIndex = 4,
        })
        local pctLbl
        if showPct then
            pctLbl = Util.Label(wrapper, {
                Text = math.floor(pbDefault * 100) .. "%",
                Color = color,
                Size = LedZ.Design.TextSmall,
                Font = LedZ.Fonts.Heading,
                FrameSize = UDim2.new(0, 50, 0, 16),
                Position = UDim2.new(1, -60, 0, 6),
                AlignX = Enum.TextXAlignment.Right,
                ZIndex = 4,
            })
        end
        local barBG = Util.Frame(wrapper, {
            Color = theme.Divider,
            Size = UDim2.new(1, -24, 0, 6),
            Position = UDim2.new(0, 12, 1, -14),
            ZIndex = 4,
        })
        Util.Round(barBG, UDim.new(1, 0))
        local fill = Util.Frame(barBG, {
            Color = color,
            Size = UDim2.new(pbDefault, 0, 1, 0),
            ZIndex = 5,
        })
        Util.Round(fill, UDim.new(1, 0))
        Util.Gradient(fill, { color, theme.AccentGlow }, 0)
        local current = pbDefault
        local Progress = { _wrapper = wrapper }
        function Progress:Set(pct, animate)
            current = Util.Clamp(pct, 0, 1)
            Util.Tween(fill, { Size = UDim2.new(current, 0, 1, 0) },
                animate == false and 0 or 0.3)
            if pctLbl then pctLbl.Text = math.floor(current * 100) .. "%" end
        end
        function Progress:Get() return current end
        function Progress:SetColor(c)
            color = c
            fill.BackgroundColor3 = c
            if pctLbl then pctLbl.TextColor3 = c end
        end
        function Progress:SetText(t) end
        function Progress:Destroy() wrapper:Destroy() end
        return Progress
    end
    function TabMeta:AddImage(opts)
        opts = opts or {}
        local imgSrc = opts.Image or ""
        local imgHeight = opts.Height or 120
        local wrapper = Util.Frame(self._scroll, {
            Color = theme.ElementBG,
            Size = UDim2.new(1, 0, 0, imgHeight),
            Name = "Image",
            ZIndex = 3,
            Clip = true,
        })
        wrapper.LayoutOrder = self:NextOrder()
        Util.Round(wrapper, UDim.new(0, 6))
        Util.Stroke(wrapper, theme.Border)
        local img = Util.Image(wrapper, {
            Image = self_ref:GetIcon(imgSrc) or imgSrc,
            Color = Color3.new(1,1,1),
            Size = UDim2.new(1, 0, 1, 0),
            Scale = opts.Scale or Enum.ScaleType.Crop,
            ZIndex = 4,
        })
        local Image = { _wrapper = wrapper, _img = img }
        function Image:SetImage(src) img.Image = self_ref:GetIcon(src) or src end
        function Image:Destroy() wrapper:Destroy() end
        return Image
    end
    function TabMeta:AddCodeBlock(opts)
        if type(opts) == "string" then opts = { Code = opts } end
        opts = opts or {}
        local codeText = opts.Code or opts.Text or ""
        local lang = opts.Language or "lua"
        local lines = {}
        for line in (codeText .. "\n"):gmatch("([^\n]*)\n") do
            table.insert(lines, line)
        end
        local lineCount = #lines
        local height = math.min(280, lineCount * 16 + 40)
        local wrapper = Util.Frame(self._scroll, {
            Color = theme.InputBG,
            Size = UDim2.new(1, 0, 0, height),
            Name = "CodeBlock",
            ZIndex = 3,
            Clip = true,
        })
        wrapper.LayoutOrder = self:NextOrder()
        Util.Round(wrapper, UDim.new(0, 6))
        Util.Stroke(wrapper, theme.Border)
        local header = Util.Frame(wrapper, {
            Color = theme.SidebarBG,
            Size = UDim2.new(1, 0, 0, 24),
            ZIndex = 4,
        })
        Util.Label(header, {
            Text = lang:upper(),
            Color = theme.TextTertiary,
            Size = LedZ.Design.TextTiny,
            Font = LedZ.Fonts.Heading,
            FrameSize = UDim2.new(1, -50, 1, 0),
            Position = UDim2.new(0, 10, 0, 0),
            ZIndex = 5,
        })
        local copyBtn = Util.ImageButton(header, {
            Image = self_ref:GetIcon("copy"),
            Color = theme.TextSecondary,
            Size = UDim2.new(0, 14, 0, 14),
            Position = UDim2.new(1, -22, 0.5, -7),
            ZIndex = 5,
        })
        local codeScroll = Util.ScrollFrame(wrapper, {
            Size = UDim2.new(1, 0, 1, -24),
            Position = UDim2.new(0, 0, 0, 24),
            BarThickness = 3,
            ZIndex = 4,
        })
        Util.Pad(codeScroll, 8, 12, 8, 12)
        local codeLbl = Util.Label(codeScroll, {
            Text = codeText,
            Color = theme.TextPrimary,
            Size = LedZ.Design.TextSmall,
            Font = LedZ.Fonts.Mono,
            FrameSize = UDim2.new(1, 0, 0, 0),
            Auto = Enum.AutomaticSize.Y,
            Wrap = false,
            AlignX = Enum.TextXAlignment.Left,
            AlignY = Enum.TextYAlignment.Top,
            ZIndex = 5,
        })
        Util.Connect(copyBtn.MouseButton1Click, function()
            if setclipboard then
                pcall(setclipboard, codeText)
                self_ref:Notify({
                    Title = "Copied",
                    Message = "Code copied to clipboard.",
                    Type = "success",
                    Duration = 2,
                })
            end
        end)
        local Code = { _wrapper = wrapper, _label = codeLbl }
        function Code:Set(t)
            codeText = t
            codeLbl.Text = t
        end
        function Code:Destroy() wrapper:Destroy() end
        return Code
    end
    function TabMeta:AddDivider() return self:AddSeparator() end
    Window._TabMeta = TabMeta
    local origAddTab = Window.AddTab
    function Window:AddTab(opts)
        local Tab = origAddTab(self, opts)
        setmetatable(Tab, { __index = TabMeta })
        Tab._window = self
        return Tab
    end
    function Window:GetTab(name)
        for _, t in ipairs(self._tabs) do
            if t._name == name then return t end
        end
        return nil
    end
    function Window:SetSize(size)
        if not size then return end
        self._size = size
        Util.Tween(self._main, { Size = size }, 0.25)
    end
    function Window:GetTheme() return self._theme end
    if autoLoad and self_ref.LoadConfig then
        task.delay(0.2, function()
            self_ref:LoadConfig(Window, autoLoad)
        end)
    end
    return Window
end

function LedZ:SetTheme(name)
    local theme = self.Themes[name]
    if not theme then return false end
    self.ActiveTheme = theme
    return true
end

function LedZ:GetThemeNames()
    local names = {}
    for n in pairs(self.Themes) do table.insert(names, n) end
    table.sort(names)
    return names
end

function LedZ:Destroy()
    if self.Util then self.Util.DisconnectAll() end
    for _, gui in ipairs({ self.NotifGui, self.DialogGui, self.TooltipGui, self.PopupGui }) do
        if gui and gui.Parent then pcall(function() gui:Destroy() end) end
    end
end

function LedZ:IsMobile() return IsMobile end
function LedZ:IsConsole() return IsConsole end
function LedZ:IsPC() return IsPC end

return LedZ
